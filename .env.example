# =============================================================================
# Hermes Agent + Honcho — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with (REQUIRED)
# =============================================================================

# =============================================================================
# LLM Provider API Keys (REQUIRED — at least one)
# =============================================================================
# Used by both Hermes Agent (for chat) and Honcho (for memory extraction)

# OpenAI API Key (REQUIRED for Hermes Agent chat if not using custom base URL)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API Key for Honcho memory extraction (falls back to OPENAI_API_KEY in docker-compose)
# LLM_OPENAI_API_KEY=sk-your-openai-api-key-here

# Custom OpenAI-compatible endpoint (optional, e.g. https://openrouter.ai/api/v1)
# OPENAI_BASE_URL=

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (optional)
# GOOGLE_API_KEY=your-google-api-key-here

# =============================================================================
# PostgreSQL Database
# =============================================================================
# Used by Honcho for storing memory, sessions, and user profiles
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=honcho

# Connection URI used by Honcho (optional, auto-constructed in docker-compose)
# DB_CONNECTION_URI=postgresql+psycopg://postgres:postgres@localhost:5432/honcho

# =============================================================================
# Redis Cache
# =============================================================================
# Connection URL used by Honcho for cache (optional, auto-constructed in docker-compose)
# CACHE_URL=redis://localhost:6379/0?suppress=true
# CACHE_ENABLED=true

# =============================================================================
# Hermes Agent Configuration
# =============================================================================
# URL of the Honcho API service (defaults to http://honcho-api:8000 in docker-compose)
# HONCHO_BASE_URL=http://localhost:8000

# Dashboard basic authentication credentials (required when binding publicly)
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=hermes-local
# 32+ byte secret to keep sessions valid across restarts
HERMES_DASHBOARD_BASIC_AUTH_SECRET=local-dev-session-secret-change-me

# Local development variables mapped in docker-compose.yml
HERMES_DASHBOARD_USERNAME=admin
HERMES_DASHBOARD_PASSWORD=hermes-local
HERMES_DASHBOARD_SECRET=local-dev-session-secret-change-me

# =============================================================================
# Honcho Configuration
# =============================================================================
# Authentication (set to true for production)
# AUTH_USE_AUTH=false
# AUTH_JWT_SECRET=generate-a-strong-secret-here

# Honcho app name for agent identification
HONCHO_APP_NAME=hermes-railway

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Custom LLM overrides for Honcho API + Deriver (OpenAI-compatible providers)
# DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_MODEL_CONFIG__OVERRIDES__BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_MODEL_CONFIG__MODEL=text-embedding-3-small

# =============================================================================
# Railway-specific (auto-populated by Railway)
# =============================================================================
# These are set automatically when deploying on Railway:
# PORT                    — Railway assigns a port to each service
# DATABASE_URL            — Set when linking PostgreSQL managed service
# REDIS_URL               — Set when linking Redis managed service
# RAILWAY_PRIVATE_DOMAIN  — Internal service-to-service communication
