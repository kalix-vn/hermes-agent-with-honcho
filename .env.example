# =============================================================================
# Hermes Agent + Honcho — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with (REQUIRED)
# =============================================================================

# =============================================================================
# LLM Provider API Keys (REQUIRED — at least one)
# =============================================================================
# Used by both Hermes Agent (for chat) and Honcho (for memory extraction)

# OpenAI (recommended — works with both Hermes and Honcho out of the box)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (optional)
# GOOGLE_API_KEY=your-google-api-key-here

# =============================================================================
# PostgreSQL Database
# =============================================================================
# Used by Honcho for storing memory, sessions, and user profiles
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=honcho

# =============================================================================
# Honcho Configuration
# =============================================================================
# Authentication (set to true for production)
# AUTH_USE_AUTH=false
# AUTH_JWT_SECRET=generate-a-strong-secret-here

# Honcho app name for agent identification
HONCHO_APP_NAME=hermes-railway

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Railway-specific (auto-populated by Railway)
# =============================================================================
# These are set automatically when deploying on Railway:
# PORT                    — Railway assigns a port to each service
# DATABASE_URL            — Set when linking PostgreSQL managed service
# REDIS_URL               — Set when linking Redis managed service
# RAILWAY_PRIVATE_DOMAIN  — Internal service-to-service communication
